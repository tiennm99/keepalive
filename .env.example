# Pick one of: redis, valkey, postgresql, mysql, mongodb, couchbase
DB_TYPE=redis

# Optional: tick interval (e.g. 30s, 1m, 5m). Defaults to 1m.
# INTERVAL=1m

# --- redis / valkey ---
REDIS_URL=redis://default@127.0.0.1:6379
# VALKEY_URL=valkey://default@127.0.0.1:6379

# --- postgresql ---
# SERVICE_URI=postgres://user:pass@host:5432/dbname?sslmode=require

# --- mysql ---
# DATA_SOURCE_NAME=user:pass@tcp(host:3306)/dbname

# --- mongodb ---
# MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net
# MONGODB_DATABASE=keepalive
# MONGODB_COLLECTION=counter

# --- couchbase ---
# COUCHBASE_CONNECTION_STRING=couchbases://cb.host
# COUCHBASE_USERNAME=
# COUCHBASE_PASSWORD=
# COUCHBASE_BUCKET_NAME=
# COUCHBASE_SCOPE_NAME=_default
# COUCHBASE_COLLECTION_NAME=_default
